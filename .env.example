# Google GenAI Settings
# Set this if you want to use the Gemini API (Google AI Studio) directly
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Platform Settings
# Required if you want to use Vertex AI or other GCP services
GOOGLE_CLOUD_PROJECT=your-gcp-project-id-here
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Application Settings
ALLOW_ORIGINS=*

# ADK telemetry & artifact storage (created by Terraform/GCP infra)
LOGS_BUCKET_NAME=your-gcs-bucket-name-here
